{
	"$schema": "../node_modules/wrangler/config-schema.json",
	"name": "echo-example",
	"compatibility_date": "2026-04-23",
	"compatibility_flags": ["nodejs_als"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "ECHO",
				"class_name": "EchoDO"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["EchoDO"]
		}
	]
}
