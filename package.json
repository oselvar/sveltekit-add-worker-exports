{
	"name": "@oselvar/sveltekit-add-worker-exports",
	"version": "0.3.0",
	"description": "Vite plugin that adds Durable Object and Workflow exports to SvelteKit Cloudflare workers",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./hooks": {
			"types": "./dist/hooks.d.ts",
			"import": "./dist/hooks.js"
		},
		"./dev-bridge": {
			"types": "./dist/bridge/dev-handler.d.ts",
			"import": "./dist/bridge/dev-handler.js"
		}
	},
	"files": [
		"dist"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oselvar/sveltekit-add-worker-exports.git"
	},
	"keywords": [
		"sveltekit",
		"cloudflare",
		"workers",
		"durable-objects",
		"workflows",
		"vite-plugin"
	],
	"peerDependencies": {
		"@sveltejs/kit": ">=2",
		"esbuild": ">=0.17",
		"miniflare": ">=4",
		"vite": ">=5",
		"wrangler": ">=4"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.61.0",
		"@types/node": "^22.19.19",
		"esbuild": "^0.25.12",
		"miniflare": "^4.20260521.0",
		"np": "^11.2.1",
		"typescript": "^5.9.3",
		"vite": "^6.4.2",
		"wrangler": "^4.94.0"
	},
	"scripts": {
		"build": "tsc",
		"test": "tsc --noEmit",
		"prepublishOnly": "tsc"
	},
	"dependencies": {
		"jsonc-parser": "^3.3.1"
	}
}
