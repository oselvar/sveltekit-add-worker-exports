{
	"name": "@oselvar/sveltekit-add-worker-exports",
	"version": "0.3.1",
	"description": "Vite plugin that adds Durable Object and Workflow exports to SvelteKit Cloudflare workers",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./hooks": {
			"types": "./dist/hooks.d.ts",
			"import": "./dist/hooks.js"
		}
	},
	"files": [
		"dist"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oselvar/sveltekit-add-worker-exports.git"
	},
	"keywords": [
		"sveltekit",
		"cloudflare",
		"workers",
		"durable-objects",
		"workflows",
		"vite-plugin"
	],
	"peerDependencies": {
		"@sveltejs/kit": ">=2",
		"esbuild": ">=0.17",
		"miniflare": ">=4",
		"vite": ">=5",
		"wrangler": ">=4"
	},
	"devDependencies": {
		"@release-it/conventional-changelog": "^11.0.1",
		"@sveltejs/kit": "^2.62.0",
		"@types/node": "^25.9.1",
		"esbuild": "^0.28.0",
		"miniflare": "^4.20260601.0",
		"release-it": "^20.2.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wrangler": "^4.98.0"
	},
	"scripts": {
		"build": "tsc",
		"test": "tsc --noEmit",
		"prepublishOnly": "tsc",
		"release": "release-it"
	},
	"dependencies": {
		"jsonc-parser": "^3.3.1"
	}
}
