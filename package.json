{
	"name": "@oselvar/sveltekit-add-worker-exports",
	"version": "0.1.0",
	"description": "Vite plugin that adds Durable Object and Workflow exports to SvelteKit Cloudflare workers",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": ["dist"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/oselvar/sveltekit-add-worker-exports"
	},
	"keywords": [
		"sveltekit",
		"cloudflare",
		"workers",
		"durable-objects",
		"workflows",
		"vite-plugin"
	],
	"peerDependencies": {
		"esbuild": ">=0.17",
		"vite": ">=5",
		"wrangler": ">=4"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"esbuild": "^0.25.0",
		"tsup": "^8.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"wrangler": "^4.84.0"
	},
	"scripts": {
		"build": "tsup",
		"prepublishOnly": "tsup"
	}
}
