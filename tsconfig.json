{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"declaration": true,
		"declarationDir": "dist",
		"rootDir": "src"
	},
	"include": ["src"],
	"exclude": ["src/**/*.test.ts", "src/__fixtures__"]
}
